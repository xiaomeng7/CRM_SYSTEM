# =============================================================================
# BHT Revenue OS — Environment variables
# Copy to .env at repo root. Used by apps/crm (Railway / local).
# See docs/environment-variables.md for full inventory.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (apps/crm) — REQUIRED for API, sync, automations, import
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/crm
DATABASE_SSL=false

# -----------------------------------------------------------------------------
# ServiceM8 (packages/integrations) — REQUIRED for sync and import
# -----------------------------------------------------------------------------
SERVICEM8_API_KEY=your_servicem8_api_key

# -----------------------------------------------------------------------------
# Twilio SMS (packages/integrations) — REQUIRED for automations that send SMS
# At least one of TWILIO_SENDER_ID or TWILIO_PHONE_NUMBER must be set
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+61400000000
# TWILIO_SENDER_ID=BHtechnolog

# -----------------------------------------------------------------------------
# CRM / Automation (apps/crm) — OPTIONAL
# -----------------------------------------------------------------------------
# Company phone shown in automation SMS (not secret)
# COMPANY_PHONE=0412 345 678

# -----------------------------------------------------------------------------
# Optional / script-only (do not commit secrets)
# -----------------------------------------------------------------------------
# PORT=3000
# DRY_RUN=true
