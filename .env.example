# =============================================================================
# BHT Revenue OS — Environment variables
# Copy to .env at repo root. Used by apps/crm (Railway / local).
# See docs/environment-variables.md for full inventory.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (apps/crm) — REQUIRED for API, sync, automations, import
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/crm
DATABASE_SSL=false

# -----------------------------------------------------------------------------
# ServiceM8 (packages/integrations) — REQUIRED for sync and import
# -----------------------------------------------------------------------------
SERVICEM8_API_KEY=your_servicem8_api_key

# -----------------------------------------------------------------------------
# Twilio SMS (packages/integrations) — REQUIRED for automations that send SMS
# At least one of TWILIO_SENDER_ID or TWILIO_PHONE_NUMBER must be set
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+61400000000
# TWILIO_SENDER_ID=BHtechnolog

# -----------------------------------------------------------------------------
# CRM / Automation (apps/crm) — OPTIONAL
# -----------------------------------------------------------------------------
# Company phone shown in automation SMS (not secret)
# COMPANY_PHONE=0412 345 678

# -----------------------------------------------------------------------------
# Google Ads — cost sync (apps/crm/scripts/sync-google-ads-cost.js)
# -----------------------------------------------------------------------------
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_CUSTOMER_ID=1234567890
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890
# Optional: GOOGLE_ADS_API_VERSION=v17
# Optional: GOOGLE_ADS_SYNC_DATE=2026-03-27
# Optional: GOOGLE_ADS_SYNC_DRY_RUN=1
# Optional: GOOGLE_ADS_AUTO_CREATE_CAMPAIGNS=1 — create local campaigns when unmapped (requires migration 039)

# -----------------------------------------------------------------------------
# GA4 — behavior sync (apps/crm/scripts/sync-ga4-behavior.js, migration 042)
# -----------------------------------------------------------------------------
# Numeric property ID (or properties/123456789). Service account needs Viewer on the GA4 property.
# GA4_PROPERTY_ID=123456789
# GOOGLE_CLIENT_EMAIL=ga4-sync@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Optional: GA4_SYNC_DATE=2026-03-27 (default: yesterday local)
# Optional: GA4_SYNC_DRY_RUN=1 — fetch from GA4 but do not upsert rows

# Google Ads — publisher (POST /api/ad-publish/google; existing campaign + ad group only)
# GOOGLE_ADS_PUBLISH_DRY_RUN=1 — ad/budget/targeting: skip mutates (budget/targeting still run search reads for preview)
# GOOGLE_ADS_PUBLISH_AD_GROUP_RESOURCE=customers/1234567890/adGroups/987654321
# Or: GOOGLE_ADS_PUBLISH_AD_GROUP_ID=987654321 (combined with GOOGLE_ADS_CUSTOMER_ID)
# Or: GOOGLE_ADS_PUBLISH_CAMPAIGN_MAP={"<internal-campaign-uuid>":"customers/123/adGroups/456"}
# GOOGLE_ADS_PUBLISH_DEFAULT_FINAL_URL=https://example.com/landing
# GOOGLE_ADS_PUBLISH_AD_STATUS=PAUSED
# Budget dry-run script: cd apps/crm && pnpm run dry-run:budget -- <campaign_uuid> [+10%]
# BUDGET_DRY_RUN_CAMPAIGN_ID=
# BUDGET_DRY_RUN_CHANGE=+10%

# -----------------------------------------------------------------------------
# Optional / script-only (do not commit secrets)
# -----------------------------------------------------------------------------
# PORT=3000
# DRY_RUN=true
