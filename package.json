{
  "name": "bht-revenue-os",
  "version": "1.0.0",
  "description": "BHT Revenue OS — CRM, lead management, automation, ServiceM8 integration",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @bht/web dev",
    "dev:landing": "pnpm --filter @bht/landing-page dev",
    "dev:crm": "pnpm --filter @bht/crm start",
    "dev:report": "pnpm --filter @bht/essential-report dev",
    "dev:energy": "pnpm --filter @bht/energy-insight-lite dev",
    "dev:risk": "pnpm --filter @bht/risk-snapshot dev",
    "build:web": "pnpm --filter @bht/web build",
    "build:landing": "pnpm --filter @bht/landing-page build",
    "build:report": "pnpm --filter @bht/essential-report build",
    "build:crm": "echo 'CRM is Node runtime; no bundle step.'",
    "lint": "echo 'Add ESLint when ready.'",
    "typecheck": "echo 'Add tsc when TypeScript is introduced.'",
    "sync": "pnpm --filter @bht/crm sync",
    "automations": "pnpm --filter @bht/crm automations",
    "import:servicem8": "pnpm --filter @bht/crm import:servicem8",
    "sync:servicem8:contacts": "pnpm --filter @bht/crm run sync:servicem8:contacts",
    "sync:servicem8:contacts:node": "node --no-deprecation apps/crm/scripts/sync-servicem8-contacts.js"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0"
}
