{
  "name": "@bht/crm",
  "version": "1.0.0",
  "description": "BHT Revenue OS — CRM core, API, automation. Deploy to Railway.",
  "private": true,
  "main": "api/index.js",
  "scripts": {
    "start": "node api/index.js",
    "sync": "node api/sync-servicem8.js",
    "automations": "node scripts/run-automations.js",
    "import:servicem8:legacy": "node scripts/import-servicem8-customers.js",
    "sync:servicem8:contacts": "node --no-deprecation scripts/sync-servicem8-contacts.js",
    "sync:servicem8:all": "node --no-deprecation scripts/sync-servicem8-all-history.js",
    "db:setup": "node -e \"require('dotenv').config();const{Pool}=require('pg');const fs=require('fs');const p=new Pool({connectionString:process.env.DATABASE_URL,ssl:process.env.DATABASE_SSL==='true'?{rejectUnauthorized:false}:false});p.query(fs.readFileSync('database/schema.sql','utf8')).then(()=>{console.log('Schema OK');p.end();}).catch(e=>{console.error(e.message);p.end();});\"",
    "db:domain-migration": "node scripts/run-domain-migration.js",
    "db:servicem8-history-migration": "node scripts/run-servicem8-history-migration.js",
    "db:sync-runs-migration": "node scripts/run-sync-runs-migration.js",
    "db:segmentation-migration": "node scripts/run-segmentation-migration.js",
    "db:activities-handled-migration": "node scripts/run-activities-handled-migration.js",
    "db:reactivation-queue-migration": "node scripts/run-reactivation-queue-migration.js",
    "db:intent-classifier-migration": "node scripts/run-intent-classifier-migration.js",
    "reply-classifier": "node workers/reply-classifier-worker.js",
    "report:segmentation-comparison": "node scripts/report-segmentation-comparison.js",
    "backfill:contact-phone": "node scripts/backfill-contact-phone-from-servicem8.js",
    "cleanup:legacy-noise": "node scripts/cleanup-legacy-noise.js",
    "normalize:crm-data": "node scripts/normalize-crm-data.js",
    "report:missing-suburb": "node scripts/report-missing-suburb.js",
    "repair:suburb": "node scripts/repair-suburb-from-jobs.js",
    "db:do-not-contact-migration": "node scripts/run-do-not-contact-migration.js"
  },
  "dependencies": {
    "@bht/integrations": "workspace:*",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.11.3"
  }
}
